{
  "name": "airportal-clone",
  "version": "1.0.0",
  "description": "AirPortal file sharing clone powered by Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute airportal-db --file=./migrations/0001_init.sql",
    "db:create": "wrangler d1 create airportal-db",
    "r2:create": "wrangler r2 bucket create airportal-files"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
